{
  "name": "naija-tax-utils",
  "version": "1.0.0",
  "description": "Nigerian tax calculation utilities — VAT, PAYE, WHT, CIT, Pension, NHF. TypeScript-first, zero dependencies.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest"
  },
  "keywords": [
    "nigeria",
    "nigerian",
    "tax",
    "vat",
    "paye",
    "withholding-tax",
    "wht",
    "cit",
    "company-income-tax",
    "firs",
    "pension",
    "nhf",
    "naija",
    "finance",
    "fintech",
    "africa"
  ],
  "author": "Marcus Aregbe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OlaMarcus09/naija-tax-utils"
  },
  "homepage": "https://github.com/OlaMarcus09/naija-tax-utils#readme",
  "bugs": {
    "url": "https://github.com/OlaMarcus09/naija-tax-utils/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}
